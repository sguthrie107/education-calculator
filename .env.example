# -------------------------------------------------------
# Local development: SQLite (default, no changes needed)
# -------------------------------------------------------
DATABASE_URL=sqlite:///education.db

# -------------------------------------------------------
# Production (Railway): paste your Railway Postgres URL
# e.g. postgresql://postgres:password@host.railway.internal:5432/railway
# -------------------------------------------------------
# DATABASE_URL=postgresql://...

# Security (CHANGE IN PRODUCTION — use a long random string)
SECRET_KEY=change-me-in-production

# HTTP Basic Auth passwords — set these for each user.
# Leaving a password blank disables that account entirely.
AUTH_STEVEN_PASSWORD=
AUTH_ALYSSA_PASSWORD=
AUTH_GUEST_PASSWORD=

# Debug mode (set false in production)
DEBUG=false

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:8001
